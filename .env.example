# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Twilio (SIP trunk that feeds LiveKit) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Cliniko ---
# Shard is parsed from the key itself (e.g. a key ending "-au4" -> api.au4.cliniko.com)
CLINIKO_API_KEY=
CLINIKO_CONTACT_EMAIL=divyansh3021@gmail.com

# --- AI providers ---
# Azure OpenAI (LLM) - from your Azure OpenAI resource, using a model you've
# already deployed there (e.g. a gpt-4.1/gpt-4o deployment).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Speech (TTS, and STT fallback)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Sarvam (primary STT, for Hindi/English code-switching)
SARVAM_API_KEY=

# --- Datastore (Neon Postgres) ---
# Take the connection string from your Neon project dashboard (the pooled
# one is fine - it's what Neon shows by default) and adapt it:
#   1. scheme must be postgresql+asyncpg (not the default postgresql://)
#   2. Neon's string uses "sslmode=require" (psycopg-style) - asyncpg wants
#      "ssl=require" instead, or the connection will fail with an
#      "unexpected keyword argument 'sslmode'" error.
# Example:
DATABASE_URL=postgresql+asyncpg://neondb_owner:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?ssl=require

# --- Branches ---
# JSON list: [{"id": "branch-a", "name": "Downtown Clinic", "cliniko_business_id": 123}, ...]
# Kept as one env var so adding a branch is a one-line config change, not a code change.
CLINIC_BRANCHES=[]

# --- Admin API ---
ADMIN_API_TOKEN=change-me

# --- Observability (all optional - features degrade gracefully if unset) ---
# Any ERROR+ log line anywhere in the app gets POSTed here as JSON
# ({"source","level","logger","message","timestamp"}). Point this at
# whatever turns a webhook into a notification for you (e.g. a Zapier/n8n
# webhook trigger feeding Slack/email/SMS, or a custom endpoint).
ALERT_WEBHOOK_URL=

# Rotating log files (agent-worker.log / api.log inside this directory) -
# captures everything, not just ERROR+, for reconstructing what happened on
# a call after the fact. Defaults to ./logs, mount a volume there in Docker.
LOG_DIR=logs

# Call recording (LiveKit Egress -> Azure Blob Storage). Leave blank to
# skip recording entirely. See README for how to create the Storage
# Account + container.
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=call-recordings
